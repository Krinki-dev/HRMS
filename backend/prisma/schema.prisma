











generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DEV_TENANT_DATABASE_URL")
  directUrl = env("DEV_TENANT_DIRECT_URL")
}





model companies {
  id                    String    @id @default(uuid())
  name                  String
  legal_name            String?
  gstin                 String?
  pan                   String?
  cin                   String?
  logo_url              String?
  address               String?
  city                  String?
  state                 String?
  pincode               String?
  country               String    @default("India")
  phone                 String?
  email                 String?
  website               String?
  epf_number            String?
  esic_number           String?
  pt_number             String?
  lwf_number            String?
  sitemap_url           String?
  financial_year_start  Int       @default(4)
  working_days_month    Int       @default(26)
  overtime_threshold    Int       @default(8)
  payslip_password_type String    @default("dob")
  is_active             Boolean   @default(true)
  created_at            DateTime  @default(now())
  updated_at            DateTime  @updatedAt
  deleted_at            DateTime?

  branches      branches[]
  departments   departments[]
  designations  designations[]
  employees     employees[]
  users         users[]
  shifts        shifts[]
  holidays      holidays[]
}

model branches {
  id         String    @id @default(uuid())
  company_id String
  name       String
  address    String?
  city       String?
  state      String?
  pincode    String?
  phone      String?
  is_active  Boolean   @default(true)
  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt
  deleted_at DateTime?

  company   companies  @relation(fields: [company_id], references: [id], onDelete: Restrict, onUpdate: Cascade)
  employees employees[]

  @@index([company_id])
}

model departments {
  id           String    @id @default(uuid())
  company_id   String
  parent_id    String?
  name         String
  code         String?
  head_id      String?
  is_active    Boolean   @default(true)
  created_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt
  deleted_at   DateTime?

  company    companies     @relation(fields: [company_id], references: [id], onDelete: Restrict, onUpdate: Cascade)
  parent     departments?  @relation("DeptHierarchy", fields: [parent_id], references: [id], onDelete: Restrict, onUpdate: Cascade)
  children   departments[] @relation("DeptHierarchy")
  employees  employees[]

  @@index([company_id])
}

model designations {
  id         String    @id @default(uuid())
  company_id String
  name       String
  level      Int?
  is_active  Boolean   @default(true)
  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt
  deleted_at DateTime?

  company   companies  @relation(fields: [company_id], references: [id], onDelete: Restrict, onUpdate: Cascade)
  employees employees[]

  @@index([company_id])
}





model employees {
  id                      String    @id @default(uuid())
  company_id              String
  branch_id               String?
  department_id           String?
  designation_id          String?
  employee_code           String
  first_name              String
  last_name               String
  middle_name             String?
  father_name             String?
  mother_name             String?
  spouse_name             String?
  disability_status       Boolean   @default(false)
  date_of_birth           DateTime?
  gender                  String?
  marital_status          String?
  blood_group             String?
  personal_email          String?
  work_email              String?
  phone                   String?
  emergency_contact_name  String?
  emergency_contact_phone String?
  emergency_contact_rel   String?
  address                 String?
  city                    String?
  state                   String?
  pincode                 String?
  central_kyc_id          String?
  date_of_joining         DateTime?
  date_of_leaving         DateTime?
  employment_type         String    @default("full_time")
  status                  String    @default("active")
  reporting_to            String?
  probation_end_date      DateTime?
  confirmation_date       DateTime?
  aadhaar_number          String?   
  pan_number              String?   
  uan_number              String?
  esi_ip_number           String?
  photo_url               String?
  is_user_created         Boolean   @default(false)
  created_at              DateTime  @default(now())
  updated_at              DateTime  @updatedAt
  deleted_at              DateTime?

  company     companies     @relation(fields: [company_id], references: [id], onDelete: Restrict, onUpdate: Cascade)
  branch      branches?     @relation(fields: [branch_id], references: [id], onDelete: Restrict, onUpdate: Cascade)
  department  departments?  @relation(fields: [department_id], references: [id], onDelete: Restrict, onUpdate: Cascade)
  designation designations? @relation(fields: [designation_id], references: [id], onDelete: Restrict, onUpdate: Cascade)
  manager        employees?  @relation("ReportingHierarchy", fields: [reporting_to], references: [id], onDelete: Restrict, onUpdate: Cascade)
  direct_reports employees[] @relation("ReportingHierarchy")

  documents          employee_documents[]
  bank_accounts      employee_bank_accounts[]
  salaries           employee_salaries[]
  attendance         attendance[]
  leave_balances     leave_balances[]
  leave_applications leave_applications[]
  payslips           payslips[]
  transfers          employee_transfers[]
  exits              employee_exits[]
  user               users?
  addresses          employee_addresses[]
  education          employee_education[]
  family_members     employee_family[]
  prev_employment    employee_prev_employment[]
  onboarding_drafts  employee_onboarding_draft[]

  @@unique([company_id, employee_code])
  @@index([company_id])
  @@index([status])
}

model employee_documents {
  id             String    @id @default(uuid())
  employee_id    String
  document_type  String
  document_name  String
  document_number String
  file_name      String
  file_url       String
  expiry_date    DateTime?
  is_verified    Boolean   @default(false)
  created_at     DateTime  @default(now())
  updated_at     DateTime  @updatedAt
  deleted_at     DateTime?

  employee employees @relation(fields: [employee_id], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([employee_id])
}

model employee_bank_accounts {
  id             String    @id @default(uuid())
  employee_id    String
  bank_name      String
  account_number String    
  ifsc_code      String
  account_type   String    @default("savings")
  is_primary     Boolean   @default(true)
  verified_at    DateTime?
  created_at     DateTime  @default(now())
  updated_at     DateTime  @updatedAt
  deleted_at     DateTime?

  employee employees @relation(fields: [employee_id], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([employee_id])
}





model users {
  id             String    @id @default(uuid())
  company_id     String
  employee_id    String?   @unique
  role_id        String
  name    String?
  email             String
  phone             String?
  password_hash     String
  is_active         Boolean   @default(true)
  is_first_login    Boolean   @default(true)
  last_login_at     DateTime?
  two_fa_enabled    Boolean   @default(false)
  two_fa_secret  String?
  created_at     DateTime  @default(now())
  updated_at     DateTime  @updatedAt
  deleted_at     DateTime?

  company  companies  @relation(fields: [company_id], references: [id], onDelete: Restrict, onUpdate: Cascade)
  employee employees? @relation(fields: [employee_id], references: [id], onDelete: Restrict, onUpdate: Cascade)
  role     roles      @relation(fields: [role_id], references: [id], onDelete: Restrict, onUpdate: Cascade)
  password_resets password_resets[]
  token_blacklist token_blacklist[]

  @@unique([company_id, email])
  @@index([company_id])
  @@index([email])
}

model roles {
  id          String    @id @default(uuid())
  company_id  String?
  name        String
  description String?
  permissions String    
  is_system   Boolean   @default(false)
  created_at  DateTime  @default(now())
  updated_at  DateTime  @updatedAt
  deleted_at  DateTime?

  users users[]

  @@index([company_id])
}

model password_resets {
  id         String    @id @default(uuid())
  user_id    String
  token_hash String
  type       String    @default("reset")
  expires_at DateTime
  used       Boolean   @default(false)
  created_at DateTime  @default(now())

  user users @relation(fields: [user_id], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([user_id])
  @@index([token_hash])
}

model token_blacklist {
  id         String    @id @default(uuid())
  token_hash String
  user_id    String
  expires_at DateTime
  created_at DateTime  @default(now())

  user users @relation(fields: [user_id], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([token_hash])
}

model otp_store {
  id         String    @id @default(uuid())
  identifier String
  otp_hash   String
  purpose    String
  attempts   Int       @default(0)
  expires_at DateTime
  created_at DateTime  @default(now())

  @@index([identifier])
}

model temp_auth_tokens {
  id         String    @id @default(uuid())
  user_id    String
  token_hash String
  purpose    String
  expires_at DateTime
  used       Boolean   @default(false)
  created_at DateTime  @default(now())
}





model shifts {
  id               String    @id @default(uuid())
  company_id       String
  name             String
  start_time       String
  end_time         String
  late_grace_mins  Int       @default(15)
  early_leave_mins Int       @default(15)
  total_hours      Float     @default(9)
  week_offs        String    @default("[0,6]")
  is_active        Boolean   @default(true)
  created_at       DateTime  @default(now())
  updated_at       DateTime  @updatedAt
  deleted_at       DateTime?

  company         companies        @relation(fields: [company_id], references: [id], onDelete: Restrict, onUpdate: Cascade)
  employee_shifts employee_shifts[]

  @@index([company_id])
}

model employee_shifts {
  id             String    @id @default(uuid())
  employee_id    String
  shift_id       String
  effective_from DateTime
  effective_to   DateTime?
  created_at     DateTime  @default(now())

  shift shifts @relation(fields: [shift_id], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([employee_id])
}

model holidays {
  id                  String    @id @default(uuid())
  company_id          String
  name                String
  date                DateTime
  type                String
  applicable_branches String    @default("[]")
  recurring_yearly    Boolean   @default(false)
  year                Int
  created_at          DateTime  @default(now())
  updated_at          DateTime  @updatedAt
  deleted_at          DateTime?

  company companies @relation(fields: [company_id], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([company_id, year])
}

model attendance {
  id              String    @id @default(uuid())
  employee_id     String
  date            DateTime
  check_in        DateTime?
  check_out       DateTime?
  working_hours   Float?
  overtime_hours  Float?
  status          String    @default("absent")
  late_arrival    Boolean   @default(false)
  early_departure Boolean   @default(false)
  regularized     Boolean   @default(false)
  location_lat    Float?
  location_lng    Float?
  ip_address      String?
  ot_status       String?
  ot_type         String?
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt

  employee employees @relation(fields: [employee_id], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@unique([employee_id, date])
  @@index([employee_id])
  @@index([date])
}

model regularization_requests {
  id                 String    @id @default(uuid())
  employee_id        String
  date               DateTime
  requested_checkin  DateTime?
  requested_checkout DateTime?
  reason             String
  document_url       String?
  status             String    @default("pending")
  approved_by        String?
  approved_at        DateTime?
  rejection_reason   String?
  created_at         DateTime  @default(now())
  updated_at         DateTime  @updatedAt

  @@index([employee_id])
}

model compoff_records {
  id          String    @id @default(uuid())
  employee_id String
  worked_date DateTime
  earned_days Float
  expiry_date DateTime
  status      String    @default("active")
  granted_by  String?
  created_at  DateTime  @default(now())

  @@index([employee_id])
}





model leave_types {
  id                    String    @id @default(uuid())
  company_id            String
  name                  String
  code                  String
  is_paid               Boolean   @default(true)
  accrual_type          String    @default("monthly")
  accrual_days          Float     @default(1)
  accrual_from          String    @default("joining")
  prorate_first_month   Boolean   @default(true)
  max_balance           Float?
  carry_forward         Boolean   @default(false)
  max_carry_forward     Float?
  encashable            Boolean   @default(false)
  min_days_per_app      Float     @default(0.5)
  max_days_per_app      Float?
  advance_notice_days   Int       @default(0)
  allow_past_date       Boolean   @default(false)
  gap_between_apps_days Int       @default(0)
  half_day_allowed      Boolean   @default(true)
  document_required     String    @default("never")
  document_after_days   Int?
  gender_specific       String    @default("all")
  min_service_months    Int       @default(0)
  is_active             Boolean   @default(true)
  created_at            DateTime  @default(now())
  updated_at            DateTime  @updatedAt
  deleted_at            DateTime?

  leave_balances     leave_balances[]
  leave_applications leave_applications[]

  @@index([company_id])
}

model leave_balances {
  id            String    @id @default(uuid())
  employee_id   String
  leave_type_id String
  year          Int
  opening       Float     @default(0)
  accrued       Float     @default(0)
  used          Float     @default(0)
  pending       Float     @default(0)
  lapsed        Float     @default(0)
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt

  employee   employees   @relation(fields: [employee_id], references: [id], onDelete: Restrict, onUpdate: Cascade)
  leave_type leave_types @relation(fields: [leave_type_id], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@unique([employee_id, leave_type_id, year])
  @@index([employee_id])
}

model leave_applications {
  id               String    @id @default(uuid())
  employee_id      String
  leave_type_id    String
  from_date        DateTime
  to_date          DateTime
  days             Float
  half_day         Boolean   @default(false)
  half_day_session String?
  reason           String?
  document_url     String?
  status           String    @default("pending")
  approved_by      String?
  approved_at      DateTime?
  rejection_reason String?
  cancelled_at     DateTime?
  created_at       DateTime  @default(now())
  updated_at       DateTime  @updatedAt

  employee   employees   @relation(fields: [employee_id], references: [id], onDelete: Restrict, onUpdate: Cascade)
  leave_type leave_types @relation(fields: [leave_type_id], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([employee_id])
  @@index([status])
}

model leave_encashments {
  id            String    @id @default(uuid())
  employee_id   String
  leave_type_id String
  days          Float
  per_day_value Int
  total_amount  Int
  status        String    @default("pending")
  add_to_payroll Boolean  @default(true)
  payslip_id    String?
  approved_by   String?
  approved_at   DateTime?
  created_at    DateTime  @default(now())
}





model salary_structures {
  id         String    @id @default(uuid())
  company_id String
  name       String
  components String
  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt
  deleted_at DateTime?

  employee_salaries employee_salaries[]

  @@index([company_id])
}

model employee_salaries {
  id                  String    @id @default(uuid())
  employee_id         String
  salary_structure_id String
  ctc_annual          Int
  basic               Int
  hra                 Int
  da                  Int?
  ta                  Int?
  special_allowance   Int?
  other_earnings      String?
  gross_monthly       Int
  pf_employee         Int?
  pf_employer         Int?
  esi_employee        Int?
  esi_employer        Int?
  pt_monthly          Int?
  tds_monthly         Int?
  net_monthly         Int
  effective_from      DateTime
  effective_to        DateTime?
  created_at          DateTime  @default(now())
  updated_at          DateTime  @updatedAt

  employee         employees         @relation(fields: [employee_id], references: [id], onDelete: Restrict, onUpdate: Cascade)
  salary_structure salary_structures @relation(fields: [salary_structure_id], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([employee_id])
}

model payroll_runs {
  id               String    @id @default(uuid())
  company_id       String
  month            Int
  year             Int
  total_employees  Int       @default(0)
  total_gross      Int       @default(0)
  total_deductions Int       @default(0)
  total_net        Int       @default(0)
  status           String    @default("draft")
  processed_at     DateTime?
  locked_at        DateTime?
  processed_by     String?
  locked_by        String?
  created_at       DateTime  @default(now())
  updated_at       DateTime  @updatedAt

  payslips payslips[]

  @@unique([company_id, month, year])
  @@index([company_id])
}

model payslips {
  id                String    @id @default(uuid())
  payroll_run_id    String
  employee_id       String
  month             Int
  year              Int
  working_days      Int
  present_days      Float
  lop_days          Float     @default(0)
  paid_days         Float
  gross             Int
  basic             Int
  hra               Int
  da                Int       @default(0)
  ta                Int       @default(0)
  special_allowance Int       @default(0)
  other_earnings    Int       @default(0)
  pf_employee       Int       @default(0)
  pf_employer       Int       @default(0)
  esi_employee      Int       @default(0)
  esi_employer      Int       @default(0)
  pt                Int       @default(0)
  tds               Int       @default(0)
  lwf_employee      Int       @default(0)
  lwf_employer      Int       @default(0)
  other_deductions  Int       @default(0)
  total_deductions  Int
  net_salary        Int
  pdf_url           String?
  is_published      Boolean   @default(false)
  created_at        DateTime  @default(now())
  updated_at        DateTime  @updatedAt

  payroll_run payroll_runs @relation(fields: [payroll_run_id], references: [id], onDelete: Restrict, onUpdate: Cascade)
  employee    employees    @relation(fields: [employee_id], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@unique([payroll_run_id, employee_id])
  @@index([employee_id])
}

model payroll_bonuses {
  id             String    @id @default(uuid())
  payroll_run_id String
  employee_id    String
  bonus_type     String
  amount         Int
  taxable        Boolean   @default(true)
  notes          String?
  created_by     String?
  created_at     DateTime  @default(now())
}

model employee_transfers {
  id               String    @id @default(uuid())
  employee_id      String
  type             String
  from_department  String?
  to_department    String?
  from_branch      String?
  to_branch        String?
  from_designation String?
  to_designation   String?
  from_manager     String?
  to_manager       String?
  effective_date   DateTime
  reason           String?
  letter_url       String?
  created_by       String?
  created_at       DateTime  @default(now())

  employee employees @relation(fields: [employee_id], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([employee_id])
}

model employee_exits {
  id                  String    @id @default(uuid())
  employee_id         String
  separation_type     String
  last_working_date   DateTime?
  notice_period_days  Int?
  notice_served       String?
  reason              String?
  exit_interview_date DateTime?
  status              String    @default("initiated")
  fnf_processed       Boolean   @default(false)
  created_by          String?
  created_at          DateTime  @default(now())
  updated_at          DateTime  @updatedAt

  employee        employees             @relation(fields: [employee_id], references: [id], onDelete: Restrict, onUpdate: Cascade)
  checklist_items exit_checklist_items[]

  @@index([employee_id])
}

model exit_checklist_items {
  id           String    @id @default(uuid())
  exit_id      String
  item_name    String
  completed    Boolean   @default(false)
  completed_by String?
  completed_at DateTime?
  notes        String?

  exit employee_exits @relation(fields: [exit_id], references: [id], onDelete: Restrict, onUpdate: Cascade)
}

model fnf_settlements {
  id               String    @id @default(uuid())
  employee_id      String
  exit_id          String
  salary_days      Int       @default(0)
  salary_amount    Int       @default(0)
  leave_encashment Int       @default(0)
  gratuity         Int       @default(0)
  reimbursements   Int       @default(0)
  notice_recovery  Int       @default(0)
  loan_recovery    Int       @default(0)
  total_payable    Int
  payslip_id       String?
  processed_by     String?
  processed_at     DateTime?
  created_at       DateTime  @default(now())
}





model tds_declarations {
  id                String    @id @default(uuid())
  employee_id       String
  financial_year    String
  regime            String    @default("new")
  hra_rent          Int       @default(0)
  landlord_pan      String?
  section_80c       Int       @default(0)
  section_80d       Int       @default(0)
  section_80g       Int       @default(0)
  home_loan_interest Int      @default(0)
  lta               Int       @default(0)
  other_deductions  String?
  estimated_tax     Int       @default(0)
  monthly_tds       Int       @default(0)
  submitted_at      DateTime?
  created_at        DateTime  @default(now())
  updated_at        DateTime  @updatedAt

  @@index([employee_id])
}

model compliance_filings {
  id             String    @id @default(uuid())
  company_id     String
  filing_type    String
  period_month   Int?
  period_year    Int
  due_date       DateTime?
  status         String    @default("pending")
  ack_number     String?
  challan_number String?
  filed_at       DateTime?
  filed_by       String?
  file_url       String?
  created_at     DateTime  @default(now())
  updated_at     DateTime  @updatedAt

  @@index([company_id])
}

model compliance_files {
  id           String    @id @default(uuid())
  company_id   String
  filing_id    String?
  file_type    String
  file_url     String
  file_name    String
  period_month Int?
  period_year  Int?
  created_at   DateTime  @default(now())
}

model pt_slabs {
  id                String    @id @default(uuid())
  state             String
  min_salary        Int
  max_salary        Int?
  pt_amount         Int
  applicable_months String?
  created_at        DateTime  @default(now())
}

model lwf_rules {
  id                    String    @id @default(uuid())
  state                 String    @unique
  employee_contribution Int
  employer_contribution Int
  frequency             String    @default("half_yearly")
  deduction_months      String    @default("[6,12]")
  created_at            DateTime  @default(now())
}





model job_requisitions {
  id              String    @id @default(uuid())
  company_id      String
  job_title       String
  department_id   String?
  designation_id  String?
  positions       Int       @default(1)
  employment_type String?
  experience_min  Int?
  experience_max  Int?
  salary_min      Int?
  salary_max      Int?
  job_description String?
  skills_required String    @default("[]")
  branch_id       String?
  target_date     DateTime?
  priority        String    @default("medium")
  status          String    @default("pending_approval")
  filled_count    Int       @default(0)
  approved_by     String?
  created_by      String?
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt
  deleted_at      DateTime?

  job_postings job_postings[]

  @@index([company_id])
}

model job_postings {
  id               String    @id @default(uuid())
  requisition_id   String
  company_id       String
  post_internal    Boolean   @default(false)
  post_career_page Boolean   @default(false)
  post_naukri      Boolean   @default(false)
  post_linkedin    Boolean   @default(false)
  post_indeed      Boolean   @default(false)
  deadline         DateTime?
  status           String    @default("active")
  external_ids     String?
  created_at       DateTime  @default(now())
  updated_at       DateTime  @updatedAt

