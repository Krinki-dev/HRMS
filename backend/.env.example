# ================================================================
# SYNTERN HRMS — ENVIRONMENT VARIABLES EXAMPLE
# ================================================================
# Copy this file to .env and fill in your values.
# NEVER commit the real .env file to git.
# ================================================================

# ---------------------------------------------------------------
# SERVER
# ---------------------------------------------------------------
NODE_ENV=development
PORT=5000
API_PREFIX=/api/v1
FRONTEND_URL=http://localhost:5173

# ---------------------------------------------------------------
# JWT AUTHENTICATION
# NOTE: auth.service.js uses JWT_ACCESS_SECRET and JWT_REFRESH_SECRET
# ---------------------------------------------------------------
JWT_ACCESS_SECRET=your_super_secret_access_key_min_32_chars
JWT_REFRESH_SECRET=your_super_secret_refresh_key_min_32_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ---------------------------------------------------------------
# DATABASE - POSTGRESQL (Supabase or self-hosted)
# ---------------------------------------------------------------
# Tenant DB (main HRMS data)
DEV_TENANT_DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/hrms_tenant?schema=public
DEV_TENANT_DIRECT_URL=postgresql://USER:PASSWORD@HOST:5432/hrms_tenant?schema=public
DEV_TENANT_SCHEMA=_template

# Central DB (super-admin, billing, tenant registry)
CENTRAL_DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/hrms_central?schema=public
CENTRAL_DIRECT_URL=postgresql://USER:PASSWORD@HOST:5432/hrms_central?schema=public

# ---------------------------------------------------------------
# REDIS
# ---------------------------------------------------------------
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# ---------------------------------------------------------------
# MINIO FILE STORAGE
# ---------------------------------------------------------------
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=hrms-files
MINIO_REGION=us-east-1

# ---------------------------------------------------------------
# EMAIL (SMTP / Nodemailer)
# ---------------------------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=HRMS Syntern <noreply@syntern.in>

# ---------------------------------------------------------------
# LOGGING
# ---------------------------------------------------------------
LOG_LEVEL=debug

# ---------------------------------------------------------------
# ENCRYPTION (AES-256 for Aadhaar, PAN, bank account numbers)
# ---------------------------------------------------------------
ENCRYPTION_KEY=your_32_byte_hex_encryption_key_here

# ---------------------------------------------------------------
# SUPER ADMIN (first run only)
# ---------------------------------------------------------------
SUPER_ADMIN_EMAIL=admin@syntern.in
SUPER_ADMIN_PASSWORD=ChangeMe@123

# ---------------------------------------------------------------
# CORS
# ---------------------------------------------------------------
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ---------------------------------------------------------------
# RATE LIMITING
# ---------------------------------------------------------------
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ---------------------------------------------------------------
# BULLMQ / QUEUE
# ---------------------------------------------------------------
QUEUE_REDIS_URL=redis://localhost:6379

# ---------------------------------------------------------------
# GST API (optional — for GSTIN auto-fill on registration form)
# Without this, GSTIN lookup still extracts state/PAN/entity type
# from the GSTIN format itself. Set this for full auto-fill.
# Get credentials by registering as a GST Suvidha Provider (GSP).
# ---------------------------------------------------------------
# GST_API_KEY=your_gsp_bearer_token_here

# ---------------------------------------------------------------
# LOGIN DEBUG CHECKLIST (remove in production)
# ---------------------------------------------------------------
# If login fails silently (no error in browser console):
# 1. Check server logs for [AUTH] and [CONTROLLER] prefix lines
# 2. Verify user exists in DB: SELECT * FROM users WHERE email='your@email.com';
# 3. Check is_active=true in users table
# 4. Check deleted_at IS NULL in users table (should be NULL for new users)
# 5. Verify password_hash matches: use bcrypt.compare() in node REPL
# 6. Confirm JWT_ACCESS_SECRET and JWT_REFRESH_SECRET are set in .env
# 7. Confirm DEV_TENANT_DATABASE_URL points to correct DB
# 8. Run: SELECT * FROM central_user_index WHERE email='your@email.com';
# 9. Run: npx prisma db push (to apply schema changes including name field)
# ---------------------------------------------------------------
